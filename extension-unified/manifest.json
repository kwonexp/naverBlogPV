{
  "manifest_version": 3,
  "name": "Naver Blog Rank Toolkit",
  "version": "1.0.0",
  "description": "Extract rank table rows or aggregate top-view posts from Naver Blog stats.",
  "permissions": [
    "activeTab",
    "tabs",
    "downloads",
    "webNavigation",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://blog.naver.com/*",
    "https://admin.blog.naver.com/*",
    "https://section.blog.naver.com/*",
    "https://blog.stat.naver.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Naver Rank Toolkit"
  },
  "content_scripts": [
    {
      "matches": [
        "https://blog.naver.com/*",
        "https://admin.blog.naver.com/*",
        "https://section.blog.naver.com/*",
        "https://blog.stat.naver.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
