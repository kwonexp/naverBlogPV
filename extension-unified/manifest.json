{
  "manifest_version": 3,
  "name": "Naver Blog Rank Toolkit",
  "version": "1.0.1",
  "description": "Extract rank table rows or aggregate top-view posts from Naver Blog stats.",
  "permissions": [
    "downloads",
    "webNavigation",
    "clipboardWrite"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Naver Rank Toolkit",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://blog.stat.naver.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
